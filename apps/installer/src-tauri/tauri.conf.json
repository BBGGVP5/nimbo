{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nimbo Setup",
  "version": "1.0.0",
  "identifier": "com.nimbo.setup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nimbo Setup",
        "width": 1080,
        "height": 680,
        "minWidth": 780,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "../../ui/src-tauri/icons/32x32.png",
      "../../ui/src-tauri/icons/128x128.png",
      "../../ui/src-tauri/icons/128x128@2x.png",
      "../../ui/src-tauri/icons/icon.png",
      "../../ui/src-tauri/icons/icon.ico"
    ]
  }
}
